<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <title>ERa Robot Control Center</title>
    
    <script src="https://www.unpkg.com/@eohjsc/era-widget@1.1.3/src/index.js"></script>

    <style>
        body { 
            font-family: 'Segoe UI', Arial, sans-serif; 
            text-align: center; 
            background: #0a0a0a; 
            color: #fff; 
            margin: 0; 
            padding-bottom: 30px;
            overflow: hidden; 
            touch-action: none; 
        }
        
        .header { 
            background: #1a1a1a; 
            padding: 15px; 
            font-size: 20px; 
            font-weight: bold;
            color: #00e5ff; 
            border-bottom: 2px solid #00e5ff; 
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        #joy-outer { 
            position: relative; 
            width: 260px; 
            height: 260px; 
            margin: 20px auto; 
            background: #111; 
            border-radius: 50%; 
            border: 4px solid #333; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.1);
        }

        .ctrl-group { 
            margin: 15px; 
            display: flex; 
            justify-content: center; 
            gap: 15px; 
        }

        .btn { 
            padding: 15px 25px; 
            font-size: 14px; 
            font-weight: bold; 
            border-radius: 30px; 
            border: none; 
            cursor: pointer; 
            color: white; 
            transition: all 0.2s;
            text-transform: uppercase;
        }

        .btn:active { transform: scale(0.9); opacity: 0.8; }
        .btn-auto { background: #00c853; box-shadow: 0 4px #008a39; }
        .btn-man { background: #ff1744; box-shadow: 0 4px #b2102f; }

        .stat-container {
            margin-top: 10px;
        }

        .stat-box { 
            background: #161616; 
            padding: 10px 20px; 
            border-radius: 12px; 
            border: 1px solid #333; 
            display: inline-block; 
            min-width: 220px;
            font-size: 14px;
        }

        b { color: #00e5ff; font-size: 16px; }

        #joystick { cursor: crosshair; }
    </style>
</head>
<body>

    <div class="header">Robot Control Center</div>

    <div id="joy-outer">
        <canvas id="joystick"></canvas>
    </div>

    <div class="ctrl-group">
        <button id="btnAuto" class="btn btn-auto">Dò Line (AUTO)</button>
        <button id="btnManual" class="btn btn-man">Dừng Tay (MAN)</button>
    </div>

    <div class="stat-container">
        <div class="stat-box">
            Mode: <b id="mode_txt">Đang kết nối...</b><br>
            Cảm biến: <b id="dist_txt">--</b> cm
        </div>
    </div>

    <script>
        // --- CẤU HÌNH ERA WIDGET ---
        const eraWidget = new EraWidget();
        let configDist = null, configMode = null, actions = [];
        
        const btnAuto = document.getElementById('btnAuto');
        const btnManual = document.getElementById('btnManual');
        const distLabel = document.getElementById('dist_txt');
        const modeLabel = document.getElementById('mode_txt');

        eraWidget.init({
            needRealtimeConfigs: true,
            needActions: true,
            maxRealtimeConfigsCount: 2, // 1: Cảm biến, 2: Trạng thái Mode
            maxActionsCount: 4,         // 0: Auto, 1: Manual, 2: Joy, 3: Stop
            
            onConfiguration: (configuration) => {
                configDist = configuration.realtime_configs[0];
                configMode = configuration.realtime_configs[1];
                actions = configuration.actions;
            },
            
            onValues: (values) => {
                // Nhận giá trị khoảng cách
                if (configDist && values[configDist.id]) {
                    distLabel.innerText = values[configDist.id].value;
                }
                // Nhận trạng thái Mode (0 hoặc 1)
                if (configMode && values[configMode.id]) {
                    modeLabel.innerText = values[configMode.id].value == 1 ? "TỰ ĐỘNG" : "THỦ CÔNG";
                }
            }
        });

        // --- SỰ KIỆN NÚT BẤM ---
        btnAuto.addEventListener('click', () => {
            if (actions[0]) eraWidget.triggerAction(actions[0].action, null);
        });

        btnManual.addEventListener('click', () => {
            if (actions[1]) eraWidget.triggerAction(actions[1].action, null);
        });

        // --- LOGIC JOYSTICK ---
        var canvas = document.getElementById('joystick');
        var ctx = canvas.getContext('2d');
        var s = 260; canvas.width = s; canvas.height = s;
        var cx = s/2, cy = s/2, ro = 85, ri = 40;
        var x = cx, y = cy, active = false;

        function draw() {
            ctx.clearRect(0,0,s,s);
            // Vòng ngoài
            ctx.beginPath(); 
            ctx.arc(cx, cy, ro, 0, Math.PI*2); 
            ctx.strokeStyle="#444"; 
            ctx.lineWidth=4; 
            ctx.stroke();
            // Nút điều khiển
            ctx.beginPath(); 
            ctx.arc(x, y, ri, 0, Math.PI*2); 
            ctx.fillStyle="#00e5ff"; 
            ctx.shadowBlur = 10;
            ctx.shadowColor = "#00e5ff";
            ctx.fill();
        }
        draw();

        function handle(e) {
            if(!active) return;
            var r = canvas.getBoundingClientRect();
            var t = e.touches ? e.touches[0] : e;
            var dx = (t.clientX - r.left) - cx, dy = (t.clientY - r.top) - cy;
            var d = Math.sqrt(dx*dx + dy*dy);
            
            if(d > ro) { dx *= ro/d; dy *= ro/d; }
            x = cx + dx; y = cy + dy; 
            draw();

            let angle = Math.round(Math.atan2(-dy, dx) * 180 / Math.PI);
            if(angle < 0) angle += 360;
            
            // Tốc độ nhân 2.6 như yêu cầu
            let speed = Math.round(Math.min(d, ro) * 2.6);

            // Gửi dữ liệu qua Action 2 của ERa (Joystick)
            // Lưu ý: Dữ liệu gửi đi là speed (hoặc angle tùy bạn cấu hình ở ESP32)
            if(actions[2]) eraWidget.triggerAction(actions[2].action, speed); 
        }

        // Sự kiện chuột & cảm ứng
        const start = () => { active = true; };
        const end = () => { 
            active = false; x=cx; y=cy; draw(); 
            if(actions[3]) eraWidget.triggerAction(actions[3].action, null); // Lệnh Dừng
        };

        canvas.onmousedown = start;
        window.onmouseup = end;
        window.onmousemove = handle;

        canvas.ontouchstart = (e) => { start(); e.preventDefault(); };
        window.ontouchend = end;
        window.ontouchmove = (e) => { handle(e); e.preventDefault(); };

    </script>
</body>
</html>
